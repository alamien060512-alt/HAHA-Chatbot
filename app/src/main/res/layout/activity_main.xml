<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/looi_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRobotName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Looi"
            android:textColor="@color/looi_text"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="online"
            android:textColor="@color/looi_accent"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <!-- TTS toggle -->
        <ImageButton
            android:id="@+id/btnTtsToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_speaker"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle voice reply"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/title_settings" />

    </LinearLayout>

    <!-- Robot face panel -->
    <FrameLayout
        android:id="@+id/robotPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/chatCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVerticalWeight="1">

        <!-- RobotFaceView added programmatically -->

        <TextView
            android:id="@+id/tvMood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="✦ idle"
            android:textColor="@color/looi_text_dim"
            android:textSize="12sp" />

    </FrameLayout>

    <!-- Chat card -->
    <LinearLayout
        android:id="@+id/chatCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/looi_surface"
        app:layout_constraintTop_toBottomOf="@id/robotPanel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVerticalWeight="1.4">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvTyping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_thinking"
            android:textColor="@color/looi_accent"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:paddingBottom="4dp"
            android:visibility="gone" />

        <!-- Input row: mic | text field | send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical">

            <!-- Mic button -->
            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_mic_button"
                android:src="@drawable/ic_mic"
                android:contentDescription="Hold to speak"
                android:padding="12dp" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/looi_text"
                android:textColorHint="@color/looi_text_dim"
                android:hint="@string/hint_message"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="3"
                android:textSize="14sp"
                android:imeOptions="actionSend" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_send"
                android:contentDescription="@string/btn_send" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
